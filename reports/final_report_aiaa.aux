\@writefile{lof}{\contentsline {figure}{\numberline {26}{\ignorespaces Pareto front of accuracy vs.\ inference time. GPR and Polynomial Regression dominate the efficient frontier. The LSTM is Pareto-dominated on both axes.}}{21}{figure.caption.33}\protected@file@percent }
\newlabel{fig:pareto_time}{{26}{21}{Pareto front of accuracy vs.\ inference time. GPR and Polynomial Regression dominate the efficient frontier. The LSTM is Pareto-dominated on both axes}{figure.caption.33}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {27}{\ignorespaces Pareto front of accuracy vs.\ interpretability. GPR occupies the top-right corner (highest accuracy, probabilistic output). Polynomial Regression is the best fully-deterministic interpretable model.}}{21}{figure.caption.34}\protected@file@percent }
\newlabel{fig:pareto_interp}{{27}{21}{Pareto front of accuracy vs.\ interpretability. GPR occupies the top-right corner (highest accuracy, probabilistic output). Polynomial Regression is the best fully-deterministic interpretable model}{figure.caption.34}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {28}{\ignorespaces OLS $R^2$ vs.\ feature count for greedy forward selection on the 17-feature Box-Cox~+ ranked strain pool. Circles = in-sample $R^2$; squares = 5-fold CV $R^2$. The CV curve peaks at $k=8$ ($R^2= 0.976$), after which additional features are collinear and slightly reduce generalization. Named feature sets are marked; the full pool ($k=17$) offers only $+0.002$ over the 8-feature optimum.}}{22}{figure.caption.35}\protected@file@percent }
\newlabel{fig:pareto_features}{{28}{22}{OLS $\Rsq $ vs.\ feature count for greedy forward selection on the 17-feature Box-Cox~+ ranked strain pool. Circles = in-sample $\Rsq $; squares = 5-fold CV $\Rsq $. The CV curve peaks at $k=8$ ($\Rsq = 0.976$), after which additional features are collinear and slightly reduce generalization. Named feature sets are marked; the full pool ($k=17$) offers only $+0.002$ over the 8-feature optimum}{figure.caption.35}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.8}Statistical Significance}{22}{subsection.7.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {29}{\ignorespaces Wilcoxon $p$-value heatmap ($|$error$|$ pairs). Dark cells indicate statistically significant differences. GPR and Polynomial Regression are significantly better than all other models ($p < 0.0001$). Random Forest, FFNN, and PINN are statistically indistinguishable from each other.}}{23}{figure.caption.36}\protected@file@percent }
\newlabel{fig:wilcoxon_pvalue}{{29}{23}{Wilcoxon $p$-value heatmap ($|$error$|$ pairs). Dark cells indicate statistically significant differences. GPR and Polynomial Regression are significantly better than all other models ($p < 0.0001$). Random Forest, FFNN, and PINN are statistically indistinguishable from each other}{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {30}{\ignorespaces Win/tie/loss matrix: each cell counts the number of test samples on which the row model has lower absolute error than the column model. GPR wins on the majority of samples against every other model.}}{23}{figure.caption.37}\protected@file@percent }
\newlabel{fig:wilcoxon_wins}{{30}{23}{Win/tie/loss matrix: each cell counts the number of test samples on which the row model has lower absolute error than the column model. GPR wins on the majority of samples against every other model}{figure.caption.37}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.9}GPR Uncertainty Quantification}{23}{subsection.7.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {31}{\ignorespaces Left --- test-set predictions with $\pm 2\sigma $ error bars. Blue points fall within the 95\% credible interval; red points are outside it. Empirical 95\% CI coverage is annotated. Right --- calibration reliability diagram: empirical coverage vs.\ nominal confidence level. A perfectly calibrated model lies on the diagonal; GPR lies slightly above, indicating mildly conservative (over-wide) intervals --- the safe direction for structural assessment.}}{24}{figure.caption.38}\protected@file@percent }
\newlabel{fig:gpr_calibration}{{31}{24}{Left --- test-set predictions with $\pm 2\sigma $ error bars. Blue points fall within the 95\% credible interval; red points are outside it. Empirical 95\% CI coverage is annotated. Right --- calibration reliability diagram: empirical coverage vs.\ nominal confidence level. A perfectly calibrated model lies on the diagonal; GPR lies slightly above, indicating mildly conservative (over-wide) intervals --- the safe direction for structural assessment}{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {32}{\ignorespaces Posterior standard deviation $\sigma $ as a function of true $g$-limit. Points are colored by absolute prediction error. Uncertainty does not grow systematically with $g$-limit, suggesting the GP kernel has similar confidence across damage severity levels. The median $\sigma $ (black line) stays below 0.05~g across the full range --- consistent with the near-perfect point-prediction accuracy (RMSE $= 0.021$~g).}}{24}{figure.caption.39}\protected@file@percent }
\newlabel{fig:gpr_uncertainty}{{32}{24}{Posterior standard deviation $\sigma $ as a function of true $g$-limit. Points are colored by absolute prediction error. Uncertainty does not grow systematically with $g$-limit, suggesting the GP kernel has similar confidence across damage severity levels. The median $\sigma $ (black line) stays below 0.05~g across the full range --- consistent with the near-perfect point-prediction accuracy (RMSE $= 0.021$~g)}{figure.caption.39}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {33}{\ignorespaces Per-feature length scales from an anisotropic Mat\'{e}rn 5/2 refit on the same training data. Shorter length scale means the kernel decays faster along that feature dimension --- i.e., the model is more sensitive to changes in that feature. Features with length scales near the upper bound (effectively $\infty $) are redundant given the other features in the set. Notably, the features identified by the optimizer as near-irrelevant (\texttt  {tip\_deflection\_slope}, \texttt  {tip\_per\_g}, inv variants) are the same collinear features excluded from \texttt  {BOXCOX\_COLS\_LR} --- an independent confirmation of the manual collinearity analysis.}}{25}{figure.caption.40}\protected@file@percent }
\newlabel{fig:gpr_length_scales}{{33}{25}{Per-feature length scales from an anisotropic Mat\'{e}rn 5/2 refit on the same training data. Shorter length scale means the kernel decays faster along that feature dimension --- i.e., the model is more sensitive to changes in that feature. Features with length scales near the upper bound (effectively $\infty $) are redundant given the other features in the set. Notably, the features identified by the optimizer as near-irrelevant (\texttt {tip\_deflection\_slope}, \texttt {tip\_per\_g}, inv variants) are the same collinear features excluded from \texttt {BOXCOX\_COLS\_LR} --- an independent confirmation of the manual collinearity analysis}{figure.caption.40}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.10}Polynomial Regression Diagnostics}{26}{subsection.7.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {34}{\ignorespaces Partial dependence plots (PDPs) for the top-4 features by linear-term coefficient magnitude. Each curve shows the marginal effect of one Box-Cox feature on the predicted $g$-limit while all other features are held at their training-set means. The relationships are smooth and monotone, consistent with the physical expectation that higher strain features imply lower $g$-limit and vice versa. The concavity visible in the avg strain and VM stress PDPs confirms that the degree-2 polynomial is capturing genuine nonlinearity rather than overfitting.}}{26}{figure.caption.41}\protected@file@percent }
\newlabel{fig:poly_pdp}{{34}{26}{Partial dependence plots (PDPs) for the top-4 features by linear-term coefficient magnitude. Each curve shows the marginal effect of one Box-Cox feature on the predicted $g$-limit while all other features are held at their training-set means. The relationships are smooth and monotone, consistent with the physical expectation that higher strain features imply lower $g$-limit and vice versa. The concavity visible in the avg strain and VM stress PDPs confirms that the degree-2 polynomial is capturing genuine nonlinearity rather than overfitting}{figure.caption.41}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.11}Random Forest Diagnostics}{27}{subsection.7.11}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {35}{\ignorespaces Top-20 feature importances for Random Forest (mean decrease in impurity). Blue bars are base engineered features; orange bars are raw strain gauge readings. The engineered features (avg strain, strain energy, \texttt  {k\_spring}) dominate the top positions despite being outnumbered 24:7 by raw gauges, confirming that the physics-derived features carry the most discriminative signal. Raw gauge importances are lower individually but collectively non-negligible, explaining why the 31-feature RF outperforms the 7-feature Linear Regression baseline.}}{27}{figure.caption.42}\protected@file@percent }
\newlabel{fig:rf_importance}{{35}{27}{Top-20 feature importances for Random Forest (mean decrease in impurity). Blue bars are base engineered features; orange bars are raw strain gauge readings. The engineered features (avg strain, strain energy, \texttt {k\_spring}) dominate the top positions despite being outnumbered 24:7 by raw gauges, confirming that the physics-derived features carry the most discriminative signal. Raw gauge importances are lower individually but collectively non-negligible, explaining why the 31-feature RF outperforms the 7-feature Linear Regression baseline}{figure.caption.42}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {36}{\ignorespaces PDPs for the four highest-importance RF features. Consistent with the GPR and Polynomial Regression PDPs (Figures~\ref {fig:gpr_uncertainty}--\ref {fig:poly_pdp}), avg strain at failure and strain energy at failure dominate, and the response curves show the same monotone decreasing character. The RF PDPs are slightly noisier at the extremes due to sparse data in those regions --- characteristic of tree ensembles.}}{28}{figure.caption.43}\protected@file@percent }
\newlabel{fig:rf_pdp}{{36}{28}{PDPs for the four highest-importance RF features. Consistent with the GPR and Polynomial Regression PDPs (Figures~\ref {fig:gpr_uncertainty}--\ref {fig:poly_pdp}), avg strain at failure and strain energy at failure dominate, and the response curves show the same monotone decreasing character. The RF PDPs are slightly noisier at the extremes due to sparse data in those regions --- characteristic of tree ensembles}{figure.caption.43}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {37}{\ignorespaces Out-of-bag (OOB) $R^2$ as a function of \texttt  {n\_estimators} using warm-start incremental fitting. The RF converges to its peak OOB $R^2$ by approximately 200 trees; adding trees beyond that yields negligible improvement. The final OOB $R^2\approx 0.948$ is consistent with the test-set $\text  {adj-}R^2= 0.956$, confirming that the model is not overfit to the training set.}}{29}{figure.caption.44}\protected@file@percent }
\newlabel{fig:rf_oob}{{37}{29}{Out-of-bag (OOB) $\Rsq $ as a function of \texttt {n\_estimators} using warm-start incremental fitting. The RF converges to its peak OOB $\Rsq $ by approximately 200 trees; adding trees beyond that yields negligible improvement. The final OOB $\Rsq \approx 0.948$ is consistent with the test-set $\adjRsq = 0.956$, confirming that the model is not overfit to the training set}{figure.caption.44}{}}
