\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Predicted vs.\ true $g$-limit plots for each model. GPR and Polynomial Regression show tight clustering along the diagonal. LSTM shows systematic bias at extreme $g$-limits.}}{12}{figure.caption.17}\protected@file@percent }
\newlabel{fig:pred_vs_true}{{10}{12}{Predicted vs.\ true $g$-limit plots for each model. GPR and Polynomial Regression show tight clustering along the diagonal. LSTM shows systematic bias at extreme $g$-limits}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Residual (predicted $-$ true) distributions. GPR and Polynomial Regression are centered near zero with narrow spread. Random Forest shows a right tail indicating occasional large overpredictions.}}{13}{figure.caption.18}\protected@file@percent }
\newlabel{fig:residual_dist}{{11}{13}{Residual (predicted $-$ true) distributions. GPR and Polynomial Regression are centered near zero with narrow spread. Random Forest shows a right tail indicating occasional large overpredictions}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces CDF of absolute test errors. GPR achieves the smallest errors across the full distribution; Polynomial Regression is the second best.}}{13}{figure.caption.19}\protected@file@percent }
\newlabel{fig:abs_error_cdf}{{12}{13}{CDF of absolute test errors. GPR achieves the smallest errors across the full distribution; Polynomial Regression is the second best}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Standardized coefficients for Linear Regression on the 6-feature Box-Cox set. Each bar shows the change in predicted $g$-limit per one-standard-deviation increase in the corresponding Box-Cox-transformed feature. Avg strain slope and max VM stress dominate; \texttt  {k\_spring} provides a distinct structural-stiffness contribution. Features that grow as damage increases carry negative coefficients (reduced $g$-limit), consistent with physical expectation.}}{14}{figure.caption.20}\protected@file@percent }
\newlabel{fig:lr_coefficients}{{13}{14}{Standardized coefficients for Linear Regression on the 6-feature Box-Cox set. Each bar shows the change in predicted $g$-limit per one-standard-deviation increase in the corresponding Box-Cox-transformed feature. Avg strain slope and max VM stress dominate; \texttt {k\_spring} provides a distinct structural-stiffness contribution. Features that grow as damage increases carry negative coefficients (reduced $g$-limit), consistent with physical expectation}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces Standardized coefficients for Polynomial Regression (degree-2 Ridge) on the 12 Box-Cox features, sorted by absolute magnitude. Blue = linear terms, red = pure quadratic terms (e.g.\ avg\_strain$^2$), teal = cross-product interaction terms. The dominant linear terms (avg strain slope, max VM stress) mirror the Linear Regression hierarchy; quadratic and interaction terms with avg strain provide the nonlinear correction that closes the accuracy gap from $\text  {adj-}R^2= 0.970$ to $0.994$.}}{15}{figure.caption.21}\protected@file@percent }
\newlabel{fig:poly_coefficients}{{14}{15}{Standardized coefficients for Polynomial Regression (degree-2 Ridge) on the 12 Box-Cox features, sorted by absolute magnitude. Blue = linear terms, red = pure quadratic terms (e.g.\ avg\_strain$^2$), teal = cross-product interaction terms. The dominant linear terms (avg strain slope, max VM stress) mirror the Linear Regression hierarchy; quadratic and interaction terms with avg strain provide the nonlinear correction that closes the accuracy gap from $\adjRsq = 0.970$ to $0.994$}{figure.caption.21}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.3}Safety Analysis}{16}{subsection.7.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Overprediction CDF. At the MOS@1\% threshold (vertical marker), GPR (MOS $= 0.078$~g) and Polynomial Regression (MOS $= 0.156$~g) both satisfy the ${<}1\%$ overprediction requirement with a margin below 0.25~g.}}{16}{figure.caption.22}\protected@file@percent }
\newlabel{fig:overpredict_cdf}{{15}{16}{Overprediction CDF. At the MOS@1\% threshold (vertical marker), GPR (MOS $= 0.078$~g) and Polynomial Regression (MOS $= 0.156$~g) both satisfy the ${<}1\%$ overprediction requirement with a margin below 0.25~g}{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Safety bar summary. GPR and Polynomial Regression (leftmost bars) are the only models below the 0.25~g MOS threshold.}}{16}{figure.caption.23}\protected@file@percent }
\newlabel{fig:safety_bars}{{16}{16}{Safety bar summary. GPR and Polynomial Regression (leftmost bars) are the only models below the 0.25~g MOS threshold}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces Absolute error vs.\ true $g$-limit. Errors tend to be higher at very low $g$-limits (heavily damaged wings), consistent with greater structural complexity in that regime.}}{17}{figure.caption.24}\protected@file@percent }
\newlabel{fig:error_vs_glimit}{{17}{17}{Absolute error vs.\ true $g$-limit. Errors tend to be higher at very low $g$-limits (heavily damaged wings), consistent with greater structural complexity in that regime}{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Conservative prediction rate ($\hat  {y} \leq y_\text  {true}$) for each model. A rate of 50\% indicates no systematic bias. Most models slightly over-predict on average (conservative rate ${<}50\%$), which is the safety-critical direction. GPR is nearly unbiased at 42.6\% conservative with median residual $+0.0003$~g.}}{17}{figure.caption.25}\protected@file@percent }
\newlabel{fig:conservative_rate}{{18}{17}{Conservative prediction rate ($\hat {y} \leq y_\text {true}$) for each model. A rate of 50\% indicates no systematic bias. Most models slightly over-predict on average (conservative rate ${<}50\%$), which is the safety-critical direction. GPR is nearly unbiased at 42.6\% conservative with median residual $+0.0003$~g}{figure.caption.25}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.4}PINN Ablation Study}{18}{subsection.7.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces PINN ablation results. Energy-rate physics (Castigliano-based) achieves the best test $R^2$ across all $\lambda $ values. Hooke-strain and strain-energy variants plateau at slightly lower $R^2$.}}{18}{figure.caption.26}\protected@file@percent }
\newlabel{fig:pinn_ablation}{{19}{18}{PINN ablation results. Energy-rate physics (Castigliano-based) achieves the best test $\Rsq $ across all $\lambda $ values. Hooke-strain and strain-energy variants plateau at slightly lower $\Rsq $}{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces Heatmap of $\text  {adj-}R^2$ for all physics model $\times $ $\lambda $ combinations. The optimal region is $\lambda \in [0.003,\, 0.01]$ for energy-rate physics.}}{18}{figure.caption.27}\protected@file@percent }
\newlabel{fig:ablation_heatmap}{{20}{18}{Heatmap of $\adjRsq $ for all physics model $\times $ $\lambda $ combinations. The optimal region is $\lambda \in [0.003,\, 0.01]$ for energy-rate physics}{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces $\lambda $ sensitivity curves. All physics models degrade at high $\lambda $ (physics term dominates and overwhelms the data loss), confirming that the physics prior is a regularizer rather than a hard constraint.}}{18}{figure.caption.28}\protected@file@percent }
\newlabel{fig:ablation_lambda}{{21}{18}{$\lambda $ sensitivity curves. All physics models degrade at high $\lambda $ (physics term dominates and overwhelms the data loss), confirming that the physics prior is a regularizer rather than a hard constraint}{figure.caption.28}{}}
